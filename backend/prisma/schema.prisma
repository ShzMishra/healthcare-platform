generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  PROVIDER
  ADMIN
  SUPER_ADMIN
}

enum ProviderType {
  DOCTOR
  CLINIC
  HOSPITAL
  LAB
}

enum ProviderStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum Theme {
  LIGHT
  DARK
}

model User {
  id String @id @default(uuid())

  name String

  email String @unique

  phone String @unique

  password String

  role Role @default(PATIENT)

  theme Theme @default(LIGHT)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  patient PatientProfile?

  provider Provider?

  searchHistory SearchHistory[]

  notifications Notification[]
}

model PatientProfile {
  id String @id @default(uuid())

  userId String @unique

  age Int?

  gender String?

  address String?

  city String?

  pincode String?

  user User @relation(fields: [userId], references: [id])

  bookings Booking[]

  reviews Review[]
}

model Provider {
  id String @id @default(uuid())

  userId String @unique

  name String

  type ProviderType

  status ProviderStatus @default(PENDING)

  address String

  city String

  pincode String

  phone String?

  whatsapp String?

  verified Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  services Service[]

  bookings Booking[]

  reviews Review[]

  availability ProviderAvailability[]
}

model Service {
  id String @id @default(uuid())

  name String

  description String?

  price Float

  providerId String

  provider Provider @relation(fields: [providerId], references: [id])

  bookings Booking[]
}

model Booking {
  id String @id @default(uuid())

  patientId String

  providerId String

  serviceId String

  date DateTime

  time String @default("00:00")

  status BookingStatus @default(PENDING)

  patient PatientProfile @relation(fields: [patientId], references: [id])

  provider Provider @relation(fields: [providerId], references: [id])

  service Service @relation(fields: [serviceId], references: [id])
}

model Review {
  id String @id @default(uuid())

  rating Int

  comment String?

  patientId String

  providerId String

  verified Boolean @default(false)

  patient PatientProfile @relation(fields: [patientId], references: [id])

  provider Provider @relation(fields: [providerId], references: [id])
}

model City {
  id String @id @default(uuid())

  name String

  active Boolean @default(false)
}

model AdminPermission {
  id String @id @default(uuid())

  adminId String

  permission String
}

model SearchHistory {
  id String @id @default(uuid())

  userId String

  query String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SearchAnalytics {
  id String @id @default(uuid())

  query String @unique

  count Int @default(1)

  updatedAt DateTime @updatedAt
}

model ProviderAvailability {
  id String @id @default(uuid())

  providerId String

  dayOfWeek String

  startTime String

  endTime String

  slotDuration Int @default(30)

  active Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])
}

model Notification {
  id String @id @default(uuid())

  userId String

  title   String
  message String

  read Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
